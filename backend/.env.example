# OpenRouter API Configuration (For AI cookie analysis)
# Sign up at https://openrouter.ai and get your API key
OPENROUTER_API_KEY=sk-or-your-actual-api-key-here

# Upstash Redis Configuration (For distributed caching)
# Optional: If not set, falls back to in-memory cache
# Sign up at https://upstash.com for free Redis instance
UPSTASH_REDIS_REST_URL=https://your-region-your-id.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# Server Configuration
PORT=5001
